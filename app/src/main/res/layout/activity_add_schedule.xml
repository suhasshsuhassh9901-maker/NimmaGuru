<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@android:color/white"
            app:navigationIconTint="@android:color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- Lang toggle -->
            <TextView
                android:id="@+id/btnLangToggle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_gravity="end"
                android:layout_marginBottom="16dp"
                android:background="@drawable/toggle_lang_bg"
                android:paddingHorizontal="14dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:text="ಕನ್ನಡ"/>

            <!-- Subject -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_subject"
                android:layout_marginBottom="20dp"
                style="@style/InputOutlined">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSubject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Day and Times -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_day"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp"/>
                    <Spinner
                        android:id="@+id/spinnerDay"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_bg"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_start_time"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="8dp"/>
                            <Spinner
                                android:id="@+id/spinnerStart"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/spinner_bg"
                                android:paddingHorizontal="12dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_end_time"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="8dp"/>
                            <Spinner
                                android:id="@+id/spinnerEnd"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/spinner_bg"
                                android:paddingHorizontal="12dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnAddSlot"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/btn_add_slot"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="1dp"
                        android:backgroundTint="@color/surface"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconTint="@color/primary"
                        android:stateListAnimator="@null"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Slots List -->
            <LinearLayout
                android:id="@+id/layoutSlots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp"/>

            <!-- Date Range -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_date_range"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <Button
                        android:id="@+id/btnDateFrom"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="@string/label_start_date"
                        android:textSize="13sp"
                        android:backgroundTint="@color/surface"
                        android:textColor="@color/text_primary"
                        app:strokeColor="@color/divider"
                        app:strokeWidth="1dp"
                        android:stateListAnimator="@null"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:id="@+id/tvDateFrom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="center_horizontal"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <Button
                        android:id="@+id/btnDateTo"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="@string/label_end_date"
                        android:textSize="13sp"
                        android:backgroundTint="@color/surface"
                        android:textColor="@color/text_primary"
                        app:strokeColor="@color/divider"
                        app:strokeWidth="1dp"
                        android:stateListAnimator="@null"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:id="@+id/tvDateTo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="center_horizontal"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Location -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_location"
                android:layout_marginBottom="20dp"
                style="@style/InputOutlined">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Max Students -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_max_students"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp"/>
            <Spinner
                android:id="@+id/spinnerMax"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/spinner_bg"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="36dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:visibility="gone"
                android:indeterminateTint="@color/primary"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/btn_add_session"
                android:textSize="16sp"
                android:backgroundTint="@color/secondary"
                android:stateListAnimator="@null"
                style="@style/BtnPrimary"/>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
